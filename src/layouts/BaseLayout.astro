---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
}

const { title, description = "A plan to update how U.S. birthright citizenship works, based on what 30 other countries already do." } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="canonical" href={canonicalURL} />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <meta name="description" content={description} />
    <meta name="author" content="JT Turner" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content="USCitizenship2032" />
    <meta property="og:image" content="https://uscitizenship2032.com/og-image.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://uscitizenship2032.com/og-image.png" />
    <title>{title}</title>

    <!-- Structured data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "USCitizenship2032",
      "url": "https://uscitizenship2032.com",
      "description": description,
      "author": {
        "@type": "Person",
        "name": "JT Turner"
      }
    })} />
  </head>
  <body class="min-h-screen flex flex-col">
    <nav class="section-dark">
      <div class="container flex items-center justify-between py-4">
        <a href="/" class="text-warm-white no-underline font-bold text-lg tracking-tight hover:text-gold-400 transition-colors">
          USCitizenship<span class="text-gold-500">2032</span>
        </a>
        <div class="hidden md:flex items-center gap-8 text-sm">
          <a href="/amendment" class="text-warm-white/80 no-underline hover:text-warm-white transition-colors">The Amendment</a>
          <a href="/comparison" class="text-warm-white/80 no-underline hover:text-warm-white transition-colors">Global Comparison</a>
          <a href="/why" class="text-warm-white/80 no-underline hover:text-warm-white transition-colors">Why This Matters</a>
          <a href="/about" class="text-warm-white/80 no-underline hover:text-warm-white transition-colors">About</a>
        </div>
      </div>
    </nav>

    <main class="flex-1">
      <slot />
    </main>

    <footer class="section-dark">
      <div class="container py-12 text-center text-warm-gray text-sm">
        <p class="mb-2">
          USCitizenship2032 is a personal project by JT Turner.
        </p>
        <p class="text-warm-white/40 mb-4">
          Not affiliated with any political party or organization.
        </p>
        <a href="https://github.com/jtwebman/uscitizenship2032" target="_blank" rel="noopener noreferrer" class="text-warm-white/50 hover:text-warm-white no-underline text-xs">View on GitHub</a>
      </div>
    </footer>
  </body>
</html>
