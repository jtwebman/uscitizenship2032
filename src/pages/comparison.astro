---
import BaseLayout from "../layouts/BaseLayout.astro";

const countries = [
  { name: "Japan", type: "sanguinis", summary: "Citizenship only if a parent is Japanese.", law: "Nationality Act, Article 2", url: "https://www.japaneselawtranslation.go.jp/en/laws/view/3929" },
  { name: "Switzerland", type: "sanguinis", summary: "Citizenship only if a parent is Swiss.", law: "Citizenship Act (BüG), Article 1", url: "https://www.fedlex.admin.ch/eli/cc/2016/404/en" },
  { name: "Israel", type: "sanguinis", summary: "Citizenship requires an Israeli citizen parent.", law: "Nationality Law 5712-1952, Section 4", url: "https://www.gov.il/en/pages/nationality-law" },
  { name: "Singapore", type: "sanguinis", summary: "Citizen only if at least one parent is Singaporean.", law: "Constitution, Article 122", url: "https://sso.agc.gov.sg/act/cons1963" },
  { name: "South Korea", type: "sanguinis", summary: "Citizenship only when a parent is Korean.", law: "Nationality Act, Article 2", url: "https://law.go.kr/LSW/lsInfoP.do?lsiSeq=269771&viewCls=engLsInfoR&urlMode=engLsInfoR" },
  { name: "Poland", type: "sanguinis", summary: "Citizenship if at least one parent is Polish.", law: "Act on Polish Citizenship, Article 14", url: "https://isap.sejm.gov.pl/isap.nsf/DocDetails.xsp?id=WDU20120000161" },
  { name: "Hungary", type: "sanguinis", summary: "Citizenship if at least one parent is Hungarian.", law: "Act LV of 1993, Section 3(1)", url: "https://njt.hu/jogszabaly/en/1993-55-00-00" },
  { name: "UAE", type: "sanguinis", summary: "Citizenship through a UAE citizen father.", law: "Federal Law No. 17 of 1972, Article 2", url: "https://legaladviceme.com/legislation/128/uae-federal-law-17-of-1972-concerning-nationality-and-passports" },
  { name: "Saudi Arabia", type: "sanguinis", summary: "Citizenship through a Saudi father.", law: "Citizenship System (1954), Article 7", url: "https://www.refworld.org/docid/3fb9eb6d2.html" },
  { name: "Sweden", type: "sanguinis", summary: "Citizenship if a parent is Swedish. No soil-based path.", law: "Citizenship Act (SFS 2001:82), Section 1", url: "https://www.riksdagen.se/sv/dokument-och-lagar/dokument/svensk-forfattningssamling/lag-200182-om-svenskt-medborgarskap_sfs-2001-82/" },
  { name: "Norway", type: "sanguinis", summary: "Citizenship if a parent is Norwegian. No soil-based path.", law: "Nationality Act, Section 4", url: "https://lovdata.no/dokument/NL/lov/2005-06-10-51/KAPITTEL_2" },
  { name: "Denmark", type: "sanguinis", summary: "Citizenship if a parent is Danish. No soil-based path.", law: "Indfødsretsloven, Section 1", url: "https://www.retsinformation.dk/eli/lta/2024/1060" },
  { name: "Finland", type: "sanguinis", summary: "Citizenship if a parent is Finnish. No soil-based path.", law: "Nationality Act 359/2003, Section 9", url: "https://www.finlex.fi/fi/laki/ajantasa/2003/20030359" },
  { name: "Netherlands", type: "sanguinis", summary: "Citizenship only by descent from a Dutch parent.", law: "Rijkswet op het Nederlanderschap, Article 3", url: "https://wetten.overheid.nl/BWBR0003738/" },
  { name: "Austria", type: "sanguinis", summary: "Citizenship only by descent from an Austrian parent.", law: "Staatsbürgerschaftsgesetz 1985, Section 7", url: "https://www.ris.bka.gv.at/GeltendeFassung.wxe?Abfrage=Bundesnormen&Gesetzesnummer=10005579" },
  { name: "Italy", type: "sanguinis", summary: "Citizenship by descent only. May acquire at age 18 with residency.", law: "Law No. 91/1992, Articles 1-2", url: "https://www.normattiva.it/uri-res/N2Ls?urn:nir:stato:legge:1992-02-05;91" },
  { name: "United Kingdom", type: "qualified", summary: "Citizen if a parent is British or has settled status. Changed 1983.", law: "British Nationality Act 1981, Section 1(1)", url: "https://www.legislation.gov.uk/ukpga/1981/61/section/1" },
  { name: "Germany", type: "qualified", summary: "Citizen if a parent has 8+ years legal residency. Added 2000.", law: "Nationality Act (StAG), Section 4(3)", url: "https://www.gesetze-im-internet.de/stag/BJNR005830913.html" },
  { name: "France", type: "qualified", summary: "Auto-citizenship at 18 with 5+ years residency. Double jus soli at birth.", law: "Civil Code, Articles 19-3 & 21-7", url: "https://www.legifrance.gouv.fr/codes/section_lc/LEGITEXT000006070721/LEGISCTA000006136738/" },
  { name: "Australia", type: "qualified", summary: "Citizen if a parent is citizen/PR. Otherwise auto-citizen at age 10.", law: "Citizenship Act 2007, Section 12", url: "https://www.legislation.gov.au/C2007A00020/latest/text", highlight: true },
  { name: "New Zealand", type: "qualified", summary: "Citizen if a parent is a NZ citizen or permanent resident.", law: "Citizenship Act 1977, Section 6", url: "https://www.legislation.govt.nz/act/public/1977/0061/latest/DLM443684.html" },
  { name: "Ireland", type: "qualified", summary: "Changed from unconditional in 2004. Now requires parental residency.", law: "Nationality Act 1956 (amended 2004), Section 6", url: "https://www.irishstatutebook.ie/eli/1956/act/26/enacted/en/html" },
  { name: "Portugal", type: "qualified", summary: "Citizen if a parent has 2+ years legal residency. Liberalized 2020.", law: "Lei da Nacionalidade (Lei n.º 37/81), Article 1", url: "https://diariodarepublica.pt/dr/legislacao-consolidada/lei/1981-34525475" },
  { name: "Belgium", type: "qualified", summary: "Citizen if a parent was also born in Belgium with 5/10yr residency.", law: "Code de la nationalité belge, Article 11", url: "https://www.ejustice.just.fgov.be/cgi_loi/change_lg.pl?language=fr&la=F&cn=1984062835&table_name=loi" },
  { name: "Spain", type: "qualified", summary: "Born to foreigners: only if stateless or parentage undetermined.", law: "Código Civil, Articles 17-19", url: "https://www.boe.es/buscar/act.php?id=BOE-A-1889-4763" },
  { name: "South Africa", type: "qualified", summary: "Citizen if a parent is SA citizen/PR. Others may apply at 18.", law: "Citizenship Act 1995, Section 2", url: "https://www.gov.za/documents/south-african-citizenship-act" },
  { name: "India", type: "qualified", summary: "Moved away from unconditional in 1986, 2003, 2019. Now requires citizen parent.", law: "Citizenship Act 1955 (amended 2003), Section 3", url: "https://www.indiacode.nic.in/handle/123456789/1522" },
  { name: "Canada", type: "unconditional", summary: "Anyone born on Canadian soil is a citizen. One of only ~30 countries worldwide.", law: "Citizenship Act (R.S.C. 1985), Section 3(1)(a)", url: "https://laws-lois.justice.gc.ca/eng/acts/c-29/page-1.html" },
  { name: "Brazil", type: "unconditional", summary: "All persons born in Brazil are citizens.", law: "Constitution (1988), Article 12, I(a)", url: "https://www.planalto.gov.br/ccivil_03/constituicao/constituicao.htm" },
  { name: "Chile", type: "unconditional", summary: "All persons born on Chilean territory are citizens.", law: "Constitution, Article 10(1)", url: "https://www.bcn.cl/leychile/navegar?idNorma=242302" },
];

const typeLabels: Record<string, { label: string; color: string; bg: string }> = {
  sanguinis: { label: "Descent Only", color: "text-teal-700", bg: "bg-teal-50" },
  qualified: { label: "Qualified", color: "text-gold-700", bg: "bg-gold-50" },
  unconditional: { label: "Unconditional", color: "text-amber-700", bg: "bg-amber-500/10" },
};
---

<BaseLayout title="Global Comparison — USCitizenship2032" description="How 30 countries handle citizenship at birth, with links to their actual laws.">
  <!-- Hero -->
  <section class="section-dark py-16 md:py-24">
    <div class="container text-center max-w-3xl">
      <p class="text-gold-500 font-semibold tracking-widest uppercase text-sm mb-4">30-Country Comparison</p>
      <h1 class="text-4xl md:text-5xl font-bold text-warm-white mb-6">How the World Does It</h1>
      <p class="text-warm-white/80 text-lg">
        Every entry links to the actual law. This isn't opinion — it's what's on the books.
      </p>
    </div>
  </section>

  <!-- Stats Bar -->
  <section class="bg-teal-50 py-10">
    <div class="container">
      <div class="grid md:grid-cols-3 gap-6 text-center">
        <div>
          <p class="text-3xl font-bold text-teal-700">16 of 30</p>
          <p class="text-sm text-teal-600">Descent only — no birthright soil citizenship</p>
        </div>
        <div>
          <p class="text-3xl font-bold text-gold-600">11 of 30</p>
          <p class="text-sm text-gold-700">Qualified — birth on soil + parental requirements</p>
        </div>
        <div>
          <p class="text-3xl font-bold text-amber-700">3 of 30</p>
          <p class="text-sm text-amber-700">Unconditional — birth on soil alone</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Legend -->
  <section class="py-10 border-b border-light-gray">
    <div class="container max-w-5xl">
      <div class="flex flex-wrap gap-6 justify-center text-sm">
        <span class="flex items-center gap-2"><span class="w-3 h-3 rounded-full bg-teal-600 shrink-0"></span> Descent Only — parentage determines citizenship</span>
        <span class="flex items-center gap-2"><span class="w-3 h-3 rounded-full bg-gold-500 shrink-0"></span> Qualified — born on soil + conditions</span>
        <span class="flex items-center gap-2"><span class="w-3 h-3 rounded-full bg-amber-500 shrink-0"></span> Unconditional — born on soil = citizen</span>
      </div>
    </div>
  </section>

  <!-- Table -->
  <section class="py-16 md:py-20">
    <div class="container max-w-6xl">
      <div class="overflow-x-auto">
        <table class="w-full text-sm border-separate border-spacing-0">
          <thead>
            <tr class="border-b-2 border-charcoal text-left">
              <th class="py-4 pr-6 font-bold w-[140px]">Nation</th>
              <th class="py-4 pr-6 font-bold w-[120px]">System</th>
              <th class="py-4 pr-6 font-bold">How It Works</th>
              <th class="py-4 font-bold w-[240px]">Source</th>
            </tr>
          </thead>
          <tbody>
            {countries.map((c) => {
              const t = typeLabels[c.type];
              return (
                <tr class={`border-b border-light-gray ${c.highlight ? "bg-gold-50" : ""}`}>
                  <td class="py-5 pr-6 font-semibold whitespace-nowrap align-top">
                    {c.name}
                    {c.highlight && <span class="block text-xs text-gold-600 font-normal mt-1">Closest to U.S. v2.0</span>}
                  </td>
                  <td class="py-5 pr-6 align-top">
                    <span class={`inline-block px-2.5 py-1 rounded text-xs font-semibold ${t.color} ${t.bg}`}>{t.label}</span>
                  </td>
                  <td class="py-5 pr-6 text-warm-gray align-top leading-relaxed">{c.summary}</td>
                  <td class="py-5 align-top">
                    <a href={c.url} target="_blank" rel="noopener noreferrer" class="text-teal-600 hover:text-teal-700 text-xs leading-snug">
                      {c.law} &rarr;
                    </a>
                  </td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Key Insights -->
  <section class="bg-charcoal py-16 md:py-20">
    <div class="container max-w-3xl">
      <h2 class="text-2xl md:text-3xl font-bold text-warm-white text-center mb-12">What the Data Shows</h2>
      <div class="space-y-8">
        <div class="flex gap-4">
          <span class="text-gold-500 text-2xl font-bold shrink-0">1</span>
          <div>
            <h3 class="text-warm-white font-bold mb-1">The U.S. is an extreme outlier</h3>
            <p class="text-warm-white/60 text-sm">Only 3 of 30 surveyed nations grant unconditional birthright citizenship. The vast majority of developed democracies moved past this model decades ago.</p>
          </div>
        </div>
        <div class="flex gap-4">
          <span class="text-gold-500 text-2xl font-bold shrink-0">2</span>
          <div>
            <h3 class="text-warm-white font-bold mb-1">Every Nordic country uses descent-only</h3>
            <p class="text-warm-white/60 text-sm">Sweden, Norway, Denmark, Finland — often cited as the world's most progressive nations — all require a citizen parent. Zero birthright soil citizenship.</p>
          </div>
        </div>
        <div class="flex gap-4">
          <span class="text-gold-500 text-2xl font-bold shrink-0">3</span>
          <div>
            <h3 class="text-warm-white font-bold mb-1">Countries have evolved away from unconditional</h3>
            <p class="text-warm-white/60 text-sm">Ireland changed via referendum in 2004. India restricted through successive amendments in 1986, 2003, and 2019. The UK changed in 1983. Democracies update their frameworks.</p>
          </div>
        </div>
        <div class="flex gap-4">
          <span class="text-gold-500 text-2xl font-bold shrink-0">4</span>
          <div>
            <h3 class="text-warm-white font-bold mb-1">Australia already does what we're proposing</h3>
            <p class="text-warm-white/60 text-sm">Australia's 10-year automatic upgrade for children of non-citizen parents is nearly identical to the proposed U.S. v2.0 vesting model. This isn't untested theory.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 md:py-20">
    <div class="container text-center max-w-2xl">
      <h2 class="text-3xl font-bold mb-4">Ready to Read the Proposal?</h2>
      <p class="text-warm-gray text-lg mb-8">
        See exactly how the proposed 28th Amendment would work — section by section, in plain English.
      </p>
      <a href="/amendment" class="btn-primary">Read the Amendment</a>
    </div>
  </section>
</BaseLayout>
